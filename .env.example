# Scriva dev-only environment overrides.
#
# Copy this file to `.env` (git-ignored) for local development. Values set here
# take precedence over keys stored via the settings UI, so you can iterate on
# the Rust pipeline without re-typing keys after every `cargo clean`.
#
# In a real installed build these vars are NOT read — production keys come
# exclusively from `tauri-plugin-store` (and, ideally, the macOS Keychain).
#
# NEVER commit a populated .env. NEVER paste real keys into pull requests.

# Transcription
SCRIVA_GROQ_KEY=
SCRIVA_OPENAI_KEY=

# Cleanup (Claude is cleanup-only — Anthropic has no STT endpoint)
SCRIVA_CLAUDE_KEY=
SCRIVA_GEMINI_KEY=
# SCRIVA_OPENAI_KEY above is reused for OpenAI cleanup as well.
