{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoiceFlow",
  "version": "0.1.0",
  "identifier": "com.voiceflow.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "VoiceFlow Settings",
        "width": 480,
        "height": 640,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
