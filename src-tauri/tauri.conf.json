{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Scriva",
  "version": "0.1.0",
  "identifier": "com.scriva.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Scriva Settings",
        "width": 480,
        "height": 640,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/soltankara/scriva/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUzMDhGODRBRTJFRTMwMUIKUldRYk1PN2lTdmdJVTVXbjc5Z2YrNkFVbWFKSURBenZRRVZ2SWVUYkFOQytvSGNybndHZHpVVWcK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "Entitlements.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}
